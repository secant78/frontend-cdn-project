option_settings:
  # NODE_ENV is also set in Terraform but repeating it here is harmless
  # and ensures it's present even on manual deployments.
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production

  # Use nginx as the reverse proxy (AL2023 default, stated explicitly).
  # The Procfile (web: node server.js) controls the start command.
  # Static files are served by Express — no staticfiles mapping needed.
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
