option_settings:
  # Load balancer — cross-zone only; HTTPS is terminated at CloudFront,
  # so no HTTPS listener is needed here (avoids placeholder ACM ARN errors).
  aws:elb:loadbalancer:
    CrossZone: true

  # Auto scaling
  aws:autoscaling:asg:
    MinSize: 1
    MaxSize: 4

  aws:autoscaling:launchconfiguration:
    InstanceType: t3.small
    IamInstanceProfile: aws-elasticbeanstalk-ec2-role

  # Health check — enhanced reporting, custom path
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced

  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /health
