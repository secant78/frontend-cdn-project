option_settings:
  # Enhanced health reporting with custom health check path.
  # All other settings (LB type, instance profile, auto-scaling, VPC)
  # are managed by Terraform — do not duplicate them here.
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced

  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /health
